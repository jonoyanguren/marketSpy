{
  "name": "@marketspy/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "mongo:start": "mkdir -p .mongodb-data && mongod --dbpath .mongodb-data --bind_ip 127.0.0.1 --port 27017"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongoose": "^9.2.4",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
